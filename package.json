{
  "name": "@blackrelay/site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=26.1.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "astro check",
    "format": "prettier --write .",
    "pages:dev": "wrangler pages dev ./dist",
    "pages:deploy": "wrangler pages deploy ./dist --project-name blackrelay-site"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "astro": "^5.15.8",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.18",
    "wrangler": "^4.105.0"
  }
}
