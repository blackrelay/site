---
import AccessPanel from "../components/AccessPanel.astro";
import EndpointMap from "../components/EndpointMap.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HeroTerminal from "../components/HeroTerminal.astro";
import PrincipleCard from "../components/PrincipleCard.astro";
import ScopePanel from "../components/ScopePanel.astro";
import SystemCard from "../components/SystemCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import { externalLinkAttrs } from "../utils/links";

const systems = [
  {
    number: "01",
    name: "REGISTRY",
    summary:
      "Public explorer for entities, systems, items, killmails, structures and source evidence.",
    state: siteConfig.systemStates.registry,
    href: siteConfig.endpoints.registry,
    serviceId: "registry",
  },
  {
    number: "02",
    name: "API",
    summary: "Public endpoints for tools, integrations and Black Relay applications.",
    state: siteConfig.systemStates.api,
    href: siteConfig.endpoints.api,
    serviceId: "api",
  },
  {
    number: "03",
    name: "API-DOCS",
    summary: "Data model, confidence labels, API reference and changelog.",
    state: siteConfig.systemStates.docs,
    href: siteConfig.endpoints.docs,
    serviceId: "docs",
  },
  {
    number: "04",
    name: "STATUS",
    summary: "Indexer freshness, API health, source staleness and incident notes.",
    state: siteConfig.systemStates.status,
    href: siteConfig.endpoints.status,
    serviceId: "status",
  },
];

const principles = [
  {
    title: "Source stays attached",
    body: "Every published record should point back to where it came from.",
  },
  {
    title: "Confidence is visible",
    body: "Verified, probable, reported, stale and unknown stay visually distinct.",
  },
  {
    title: "Current cycle comes first",
    body: "Cycle 6 Stillness records are the default public view.",
  },
  {
    title: "Private intel is out of scope",
    body: "Black Relay does not publish private Discord intel, wallet secrets or unverifiable alt accusations.",
  },
  {
    title: "Direct reads before transactions",
    body: "Re-read live Frontier and Sui state before signing, sponsoring, deploying or mutating anything.",
  },
];

const currentState = [
  ["API", "public read-only"],
  ["Registry", "public explorer"],
  ["Docs", "public"],
  ["Environment", "Stillness"],
  ["Cycle", "6"],
  ["Indexer", "active"],
  ["Static client data", "imported"],
  ["Data freshness", "mixed"],
  ["Known gaps", "patch-sensitive names/types"],
] as const;

const apiExamples = [
  "GET /v1/health",
  "GET /v1/entities",
  "GET /v1/events",
  "GET /v1/types/:id",
  "GET /v1/sources",
  "GET /v1/ops/freshness",
] as const;
---

<BaseLayout>
  <Header />
  <main id="main">
    <HeroTerminal />

    <section class="section" aria-labelledby="current-state-title">
      <div class="section-head">
        <span class="section-number">01 //</span>
        <h2 class="section-title" id="current-state-title">Current state</h2>
      </div>
      <div class="state-grid">
        {
          currentState.map(([label, value]) => (
            <article class="state-card terminal-record">
              <span>{label}</span>
              <strong>{value}</strong>
            </article>
          ))
        }
      </div>
      <p class="trust-note">
        Black Relay indexes public or source-labelled data only. It is a read layer, not
        transaction authority. Frontier data can change after patches or cycle resets, so check
        source, cycle and timestamp before relying on a record.
      </p>
    </section>

    <section class="section" aria-labelledby="systems-title">
      <div class="section-head">
        <span class="section-number">02 //</span>
        <h2 class="section-title" id="systems-title">Live surfaces</h2>
      </div>
      <div class="system-ledger">
        {systems.map((system) => <SystemCard {...system} />)}
      </div>
    </section>

    <section class="section api-section" aria-labelledby="api-title">
      <div class="section-head">
        <span class="section-number">03 //</span>
        <h2 class="section-title" id="api-title">Try the API</h2>
      </div>
      <div class="api-grid">
        <div class="api-copy">
          <p>
            These are real public endpoints. They return source-labelled Registry exports from
            Cloudflare and should be treated as read-side data.
          </p>
          <a class="terminal-button" href={siteConfig.endpoints.docs}>Read API docs</a>
        </div>
        <ul class="api-list" aria-label="Example API routes">
          {apiExamples.map((example) => <li><code>{example}</code></li>)}
        </ul>
      </div>
    </section>

    <section class="section" aria-labelledby="principles-title">
      <div class="section-head">
        <span class="section-number">04 //</span>
        <h2 class="section-title" id="principles-title">Data rules</h2>
      </div>
      <div class="principle-grid">
        {principles.map((principle) => <PrincipleCard {...principle} />)}
      </div>
    </section>

    <ScopePanel />
    <section class="section mission-section" aria-labelledby="mission-title">
      <div class="section-head">
        <span class="section-number">06 //</span>
        <h2 class="section-title" id="mission-title">Mission</h2>
      </div>
      <div class="mission-grid">
        <div>
          <p>
            The frontier speaks in broken signals. Black Relay records public EVE Frontier data
            from Sui events, World API metadata and static client data, then keeps source,
            confidence and freshness attached so builders can see what was checked, what is stale
            and what needs another read. The Registry is the public record, the API is the read
            layer and the status page shows whether the signal is current. Black Relay does not
            claim to see the whole frontier; it records what can be checked before rumour hardens
            into fact.
          </p>
        </div>
        <aside class="identity-panel terminal-record" aria-label="Maintainers">
          <span class="terminal-label">Maintainers</span>
          <p>
            Maintained by{" "}
            <a href={siteConfig.identity.founderUrl} {...externalLinkAttrs(siteConfig.identity.founderUrl)}>
              {siteConfig.identity.founderName}</a
            >{" "}
            and Black Relay contributors.
          </p>
        </aside>
      </div>
    </section>
    <EndpointMap />
    <AccessPanel />
  </main>
  <Footer />
  <script is:inline define:vars={{ statusApiUrl: siteConfig.statusApiUrl }}>
    window.BLACK_RELAY_STATUS_API_URL = statusApiUrl;
  </script>
  <script>
    import "../scripts/system-status";
  </script>
</BaseLayout>

<style>
  .system-ledger {
    display: grid;
    border-bottom: 1px solid rgba(254, 71, 0, 0.24);
  }

  .state-grid,
  .api-grid {
    display: grid;
    gap: 1rem;
  }

  .state-grid {
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
  }

  .state-card {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
  }

  .state-card span,
  .api-list code {
    color: #fe4700;
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .state-card strong {
    color: #f4f1ec;
    font-family: var(--mono);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .trust-note,
  .api-copy p {
    max-width: 820px;
    color: #b9b0a8;
  }

  .trust-note {
    margin: 1.25rem 0 0;
  }

  .api-list {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 1rem;
    border: 1px solid rgba(254, 71, 0, 0.18);
    background: rgba(5, 5, 5, 0.72);
    list-style: none;
  }

  .api-list code {
    color: #f4f1ec;
    font-size: 0.84rem;
  }

  .mission-grid {
    display: grid;
    gap: 1.25rem;
  }

  .mission-grid p {
    max-width: 760px;
    margin: 0 0 1rem;
    color: #d3ccc5;
    font-size: clamp(1.05rem, 2vw, 1.28rem);
  }

  .identity-panel {
    align-self: start;
    padding: clamp(1rem, 3vw, 1.35rem);
    border-bottom: 1px solid rgba(254, 71, 0, 0.24);
  }

  .identity-panel p {
    margin: 0.85rem 0 0;
    color: #f4f1ec;
    font-family: var(--mono);
    font-size: 0.95rem;
  }

  .identity-panel a {
    color: #f4f1ec;
    text-decoration: underline;
    text-decoration-color: rgba(254, 71, 0, 0.72);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
    transition:
      color 160ms ease,
      text-decoration-color 160ms ease;
  }

  .identity-panel a:hover {
    color: #fe4700;
    text-decoration-color: #fe4700;
  }

  .principle-grid {
    display: grid;
    gap: 0.5rem 1.5rem;
  }

  @media (min-width: 760px) {
    .principle-grid,
    .api-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .mission-grid {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 0.45fr);
      align-items: start;
    }

  }
</style>
