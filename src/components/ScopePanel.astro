---
const currentScope = [
  "entities, systems, items, events and killmails",
  "structures, sources, facts and relations",
  "public API and Registry explorer",
  "developer documentation",
  "source, confidence and freshness labels",
  "public exports and operational status",
];

const knownGaps = [
  "some source windows can be stale while upstream indexers catch up",
  "static client names and type metadata are patch-sensitive",
  "coverage is incomplete where public sources do not expose enough context",
  "the API is not transaction authority",
];
---

<section class="section" aria-labelledby="scope-title">
  <div class="section-head">
    <span class="section-number">05 //</span>
    <h2 class="section-title" id="scope-title">Current scope</h2>
  </div>
  <div class="scope-grid">
    <div class="scope-list terminal-record">
      <h3>Covered data</h3>
      <ul>
        {currentScope.map((item) => <li>{item}</li>)}
      </ul>
    </div>
    <div class="scope-list terminal-record">
      <h3>Known gaps</h3>
      <ul>
        {knownGaps.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  .scope-grid {
    display: grid;
    gap: 1rem;
  }

  @media (min-width: 760px) {
    .scope-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .scope-list {
    padding: clamp(1rem, 3vw, 1.35rem);
    border-bottom: 1px solid rgba(254, 71, 0, 0.24);
  }

  h3 {
    margin: 0 0 1rem;
    color: #fe4700;
    font-family: var(--mono);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
  }

  ul {
    display: grid;
    gap: 0.55rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  li {
    color: #b9b0a8;
  }

  li::before {
    color: #fe4700;
    content: "// ";
  }
</style>
