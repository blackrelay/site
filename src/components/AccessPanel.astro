---
import { siteConfig } from "../config/site";
import { externalLinkAttrs } from "../utils/links";

const cards = [
  {
    label: "Referral",
    title: "Use Black Relay referral",
    meta: "Active",
    detail: `CODE: ${siteConfig.eveFrontierReferralCode}`,
    href: siteConfig.eveFrontierReferralUrl,
    linkText: "Frontier referral",
  },
  {
    label: "Discord",
    title: "Join Discord",
    meta: "",
    detail: "Registry updates, source reports and early API discussion.",
    href: siteConfig.discordInviteUrl,
    linkText: "Join Discord",
  },
  {
    label: "GitHub",
    title: "Contribute on GitHub",
    meta: "",
    detail: "Public repositories for Black Relay tooling and infrastructure.",
    href: siteConfig.githubOrgUrl,
    linkText: "Open GitHub",
  },
];
---

<section class="section" aria-labelledby="access-title">
  <div class="section-head">
    <span class="section-number">08 //</span>
    <h2 class="section-title" id="access-title">Join / contribute</h2>
  </div>
  <div class="access-intro relay-line">
    <p>
      Black Relay is maintained by Hēi and Black Relay contributors.
    </p>
    <p>
      Join Discord for project updates or use GitHub to review source, report data issues and
      contribute fixes. Our referral link is available here but it is not the project front door.
    </p>
  </div>
  <div class="access-ledger">
    {
      cards.map((card) => (
        <article class="terminal-record access-row">
          <div class="access-row__meta">
            <span class="terminal-label">{card.label}</span>
            {card.meta && <span>{card.meta}</span>}
          </div>
          <div class="access-row__body">
            <h3>{card.title}</h3>
            <p>{card.detail}</p>
          </div>
          <a class="terminal-button" href={card.href} {...externalLinkAttrs(card.href)}>
            {card.linkText}
          </a>
        </article>
      ))
    }
  </div>
</section>

<style>
  .access-intro {
    display: grid;
    gap: 0.85rem;
    max-width: 760px;
    margin-bottom: 1.55rem;
    padding-left: 1.25rem;
  }

  .access-intro p,
  .access-row p {
    margin: 0;
    color: #b9b0a8;
  }

  .access-ledger {
    display: grid;
    border-bottom: 1px solid rgba(254, 71, 0, 0.24);
  }

  .access-row {
    display: grid;
    gap: 1rem;
    padding: clamp(1rem, 3vw, 1.35rem);
  }

  .access-row__meta {
    display: grid;
    gap: 0.35rem;
    align-content: start;
    color: #fe4700;
    font-family: var(--mono);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .access-row__body {
    display: grid;
    gap: 0.45rem;
  }

  h3 {
    margin: 0;
    color: #f4f1ec;
    font-family: var(--mono);
    font-size: clamp(1.05rem, 2vw, 1.45rem);
    text-transform: uppercase;
  }

  .access-row .terminal-button {
    justify-self: start;
    align-self: center;
    width: min(100%, 13.75rem);
    text-align: center;
    white-space: nowrap;
  }

  @media (min-width: 860px) {
    .access-row {
      grid-template-columns: 9.5rem minmax(0, 1fr) 13.75rem;
      align-items: center;
    }

    .access-row .terminal-button {
      justify-self: stretch;
    }
  }
</style>
