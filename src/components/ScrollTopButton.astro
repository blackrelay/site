<button class="scroll-top" type="button" aria-label="Scroll to top" data-scroll-top>
  <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
    <path d="M7 13l5-5 5 5" />
    <path d="M7 18l5-5 5 5" />
  </svg>
</button>

<script>
  const scrollTopButton = document.querySelector<HTMLButtonElement>("[data-scroll-top]");
  const siteHeader = document.querySelector<HTMLElement>(".site-header");

  if (scrollTopButton) {
    let ticking = false;

    const shouldShowButton = () => {
      if (siteHeader) {
        return siteHeader.getBoundingClientRect().bottom <= 0;
      }

      return window.scrollY > 96;
    };

    const updateButton = () => {
      scrollTopButton.dataset.visible = shouldShowButton() ? "true" : "false";
      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateButton);
        ticking = true;
      }
    };

    scrollTopButton.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    updateButton();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
  }
</script>

<style>
  .scroll-top {
    position: fixed;
    top: clamp(0.75rem, 2vw, 1.1rem);
    left: 50%;
    z-index: 30;
    display: inline-grid;
    width: 3rem;
    height: 3rem;
    padding: 0;
    place-items: center;
    border: 1px solid rgba(254, 71, 0, 0.62);
    border-radius: 999px;
    background:
      radial-gradient(circle at 50% 28%, rgba(254, 71, 0, 0.16), transparent 62%),
      rgba(0, 0, 0, 0.86);
    color: #fe4700;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, -0.6rem);
    transition:
      opacity 180ms ease,
      transform 180ms ease,
      background 180ms ease,
      border-color 180ms ease,
      color 180ms ease;
  }

  .scroll-top[data-visible="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: translate(-50%, 0);
  }

  .scroll-top:hover {
    border-color: rgba(254, 71, 0, 0.92);
    background: rgba(254, 71, 0, 0.14);
    color: #f4f1ec;
  }

  .scroll-top svg {
    width: 1.35rem;
    height: 1.35rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: square;
    stroke-linejoin: miter;
    stroke-width: 1.8;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-top {
      transition: none;
    }
  }
</style>
